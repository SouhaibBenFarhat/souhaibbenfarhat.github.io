# Copy to `.env` for local overrides. All PUBLIC_* vars are exposed in the browser
# bundle, so put ONLY non-secret values here. Real secrets (e.g. the LLM API key)
# live in the Python backend, never in the frontend.
#
# You do NOT need any of these to run locally: analytics defaults to OFF when unset.
# The deploy pipeline (.github/workflows/deploy.yml) sets the production values.

# Turn analytics on. "true" only in CI/production; leave unset/false locally.
PUBLIC_ENABLE_ANALYTICS=false

# PostHog project API key — public, safe to expose. Get it from PostHog → Project Settings.
PUBLIC_POSTHOG_KEY=

# PostHog host. EU cloud by default; use https://us.i.posthog.com for US.
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
