---
import { profile } from '../data/site';
const year = 2026;
---

<footer class="mt-24 border-t border-line">
  <div class="wrap flex flex-col items-start justify-between gap-6 py-10 sm:flex-row sm:items-center">
    <div>
      <p class="font-display text-lg">{profile.name}</p>
      <p class="mt-1 text-sm text-muted">{profile.title} · {profile.location}</p>
    </div>
    <div class="flex flex-wrap items-center gap-5 text-sm">
      <a class="link-underline" href={`mailto:${profile.email}`}>Email</a>
      <a class="link-underline" href={profile.links.linkedin} target="_blank" rel="noopener">LinkedIn</a>
      <a class="link-underline" href={profile.cv} download>CV</a>
      <a class="link-underline" href="/privacy">Privacy</a>
      <button type="button" data-cookie-settings class="cookie-settings-link link-underline">Cookie settings</button>
    </div>
  </div>
  <div class="wrap pb-10">
    <p class="text-xs text-muted">© {year} {profile.name}</p>
  </div>
</footer>

{/* Reopen the consent banner (the React island reveals this control via `.sf-consent-ready`) */}
<script is:inline>
  document
    .querySelector('[data-cookie-settings]')
    ?.addEventListener('click', () => window.dispatchEvent(new CustomEvent('sf-consent:open')));
</script>
