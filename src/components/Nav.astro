---
import { profile, nav } from '../data/site';
const initials = profile.name.split(' ').map((p) => p[0]).slice(0, 2).join('');
---

<header id="site-header" class="sticky top-0 z-40 border-b border-line/70 bg-bg/90 backdrop-blur-md">
  <nav class="wrap flex h-16 items-center justify-between gap-4">
    <a href="#home" class="group flex shrink-0 items-center gap-2.5" aria-label="Back to top">
      <span class="grid h-10 w-10 place-items-center rounded-full border border-line font-display text-sm text-accent transition-colors group-hover:border-accent">{initials}</span>
      {/* Show the name where there's room — below md (no inline nav yet) and at lg+ (wide) — but
          hide it in the md–lg band, where the nav and CV button would otherwise squeeze it to a wrap. */}
      <span class="hidden whitespace-nowrap font-display text-[0.95rem] sm:inline md:hidden lg:inline">{profile.name}</span>
    </a>

    <div class="flex items-center gap-1">
      <ul class="hidden items-center gap-1 md:flex">
        {nav.map((n) => (
          <li><a href={n.href} data-nav={n.href} class="nav-link">{n.label}</a></li>
        ))}
      </ul>

      <a href={profile.cv} class="btn-solid ml-1 hidden shrink-0 whitespace-nowrap sm:inline-flex" download>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 5 5-5M5 21h14"/></svg>
        Download CV
      </a>

      <button id="theme-toggle" type="button" aria-label="Toggle theme" class="ml-1 grid h-11 w-11 place-items-center rounded-full border border-line text-muted transition-colors hover:border-accent hover:text-accent">
        <svg class="h-4 w-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="hidden h-4 w-4 dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>

      <button id="menu-toggle" type="button" aria-label="Menu" aria-expanded="false" aria-controls="mobile-menu" class="ml-1 grid h-11 w-11 place-items-center rounded-full border border-line text-ink/80 md:hidden">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </div>
  </nav>

  {/* Mobile menu */}
  <div id="mobile-menu" class="hidden border-t border-line md:hidden">
    <ul class="wrap flex flex-col gap-1 py-3">
      {nav.map((n) => (
        <li><a href={n.href} data-nav={n.href} class="nav-link block rounded-lg">{n.label}</a></li>
      ))}
      <li><a href={profile.cv} class="btn-solid mt-2 w-full justify-center" download>Download CV</a></li>
    </ul>
  </div>
</header>

<script is:inline>
  const themeToggle = document.getElementById('theme-toggle');
  const themeMeta = document.getElementById('sf-theme-color');
  // Keep the toggle's pressed state and the browser-chrome colour in step with the theme.
  const syncTheme = () => {
    const dark = document.documentElement.classList.contains('dark');
    themeToggle?.setAttribute('aria-pressed', String(dark));
    themeMeta?.setAttribute('content', dark ? '#0d0f12' : '#faf8f4');
  };
  syncTheme();
  themeToggle?.addEventListener('click', () => {
    const root = document.documentElement;
    root.classList.toggle('dark');
    localStorage.setItem('theme', root.classList.contains('dark') ? 'dark' : 'light');
    syncTheme();
  });

  const menuBtn = document.getElementById('menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  const closeMenu = (returnFocus) => {
    mobileMenu?.classList.add('hidden');
    menuBtn?.setAttribute('aria-expanded', 'false');
    if (returnFocus) menuBtn?.focus();
  };
  menuBtn?.addEventListener('click', () => {
    const hidden = mobileMenu?.classList.toggle('hidden');
    menuBtn.setAttribute('aria-expanded', String(hidden === false));
  });
  mobileMenu?.querySelectorAll('a[data-nav]').forEach((a) =>
    a.addEventListener('click', () => closeMenu(false))
  );
  // Escape closes the open menu and returns focus to the toggle that opened it.
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && mobileMenu && !mobileMenu.classList.contains('hidden')) closeMenu(true);
  });

  const header = document.getElementById('site-header');
  const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 8);
  onScroll();
  window.addEventListener('scroll', onScroll, { passive: true });

  // Scroll-spy: highlight the nav item for the section currently in view
  const navLinks = Array.from(document.querySelectorAll('[data-nav]'));
  const ids = ['home', 'about', 'experience', 'work', 'projects', 'skills', 'contact'];
  const sections = ids.map((id) => document.getElementById(id)).filter(Boolean);
  const setActive = (id) =>
    navLinks.forEach((l) => {
      const active = l.getAttribute('data-nav') === '#' + id;
      l.classList.toggle('is-active', active);
      if (active) l.setAttribute('aria-current', 'true');
      else l.removeAttribute('aria-current');
    });
  const spy = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((e) => e.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible[0]) setActive(visible[0].target.id);
    },
    { rootMargin: '-30% 0px -60% 0px', threshold: 0 }
  );
  sections.forEach((s) => spy.observe(s));
</script>
