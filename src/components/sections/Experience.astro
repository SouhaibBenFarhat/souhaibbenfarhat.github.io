---
import { experience, education, languages } from '../../data/site';
---
<section id="experience" class="scroll-mt-24 border-t border-line">
  <div class="wrap py-16 sm:py-20">
    <p class="label">Experience</p>
    <h2 class="mt-4 max-w-3xl font-display text-3xl leading-tight tracking-tight sm:text-4xl">
      Where I've worked
    </h2>
    <p class="mt-5 max-w-prose text-[0.95rem] leading-relaxed text-muted">
      Building SaaS products in Munich since 2018 — frontend depth throughout, broadening into backend,
      architecture, and AI.
    </p>

    <div class="mt-8">
      {experience.map((r) => (
        <article class="reveal grid scroll-mt-24 gap-6 border-t border-line py-12 first:border-t-0 first:pt-0 md:grid-cols-[0.7fr_2fr]">
          <div>
            <p class="font-display text-xl">
              {r.url ? (
                <a
                  href={r.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="underline decoration-line decoration-1 underline-offset-4 transition-colors hover:text-accent hover:decoration-accent"
                >
                  {r.company}
                </a>
              ) : (
                r.company
              )}
            </p>
            <p class="mt-1 text-sm text-muted">{r.role}</p>
            <p class="mt-3 text-xs uppercase tracking-label text-muted">{r.period}</p>
            <p class="text-xs text-muted">{r.location}</p>
          </div>
          <div>
            {r.blurb && <p class="max-w-prose text-[0.95rem] italic leading-relaxed text-muted">{r.blurb}</p>}
            {r.points.length > 0 && (
              <ul class="mt-4 space-y-3">
                {r.points.map((pt) => (
                  <li class="flex gap-3 text-[0.95rem] leading-relaxed">
                    <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
                    <span>{pt}</span>
                  </li>
                ))}
              </ul>
            )}
            <div class="mt-5 flex flex-wrap gap-2">
              {r.stack.map((s) => <span class="tag">{s}</span>)}
            </div>
          </div>
        </article>
      ))}
    </div>

    <div class="mt-16 grid gap-12 md:grid-cols-2">
      <div class="reveal">
        <p class="label">Education</p>
        <ul class="mt-6 space-y-6">
          {education.map((e) => (
            <li class="border-l border-line pl-5">
              <p class="font-display text-lg leading-tight">{e.school}</p>
              <p class="mt-1 text-[0.95rem] text-muted">{e.detail}</p>
              <p class="mt-1 text-xs uppercase tracking-label text-muted">{e.years} · {e.place}</p>
            </li>
          ))}
        </ul>
      </div>
      <div class="reveal">
        <p class="label">Languages</p>
        <ul class="mt-6 space-y-4">
          {languages.map((l) => (
            <li class="flex items-center justify-between border-b border-line pb-3 text-[0.95rem]">
              <span>{l.name}</span><span class="text-sm text-muted">{l.level}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
