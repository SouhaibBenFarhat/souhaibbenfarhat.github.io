---
import { profile, highlights } from '../../data/site';
---
<section id="home" class="scroll-mt-24">
  <div class="wrap pb-12 pt-20 sm:pt-28">
    <p class="label animate-rise">{profile.name}</p>
    <h1 class="mt-4 font-display text-[clamp(2.25rem,4.6vw,3.25rem)] font-medium leading-[1.05] tracking-tight text-balance">
      {profile.title}
    </h1>
    <h2 class="mt-3 max-w-prose font-display text-2xl font-medium leading-tight tracking-tight sm:text-3xl">
      8+ years building SaaS products
    </h2>
    <h3 class="mt-5 max-w-prose font-display text-lg font-normal leading-snug text-muted sm:text-xl">
      {profile.tagline}
    </h3>
    <p class="mt-4 max-w-prose text-[0.95rem] leading-relaxed text-muted">
      React, TypeScript &amp; Python · {profile.location} · {profile.availability}
    </p>
    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a href={profile.cv} class="btn-solid" download>
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 5 5-5M5 21h14"/></svg>
        Download CV
      </a>
      <a href="#projects" class="btn">See what I've shipped</a>
      <a href="#contact" class="btn">Get in touch</a>
    </div>
  </div>

  <div class="wrap"><hr class="hr" /></div>

  <div class="wrap py-14 sm:py-16">
    <p class="label reveal">In short</p>
    <div class="mt-8 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2">
      {highlights.map((h, i) => (
        <div class="reveal bg-surface p-7" style={`transition-delay:${i * 70}ms`}>
          <p class="font-display text-lg text-accent">{h.k}</p>
          <p class="mt-2 text-[0.95rem] leading-relaxed text-muted">{h.v}</p>
        </div>
      ))}
    </div>
  </div>
</section>
