---
import { highlights } from '../../data/site';

// The "In short" value props. Split out of Hero.astro so the Showcase can sit directly under the
// hero copy: these are claims, and the products that back them should come first. Separated with
// a border-t like the other sections, replacing the standalone <hr> it used to sit behind.
---
<section class="scroll-mt-24 border-t border-line">
  <div class="wrap py-14 sm:py-16">
    <p class="label reveal">In short</p>
    <div class="mt-8 grid gap-px overflow-hidden rounded-2xl border border-line bg-line sm:grid-cols-2">
      {highlights.map((h, i) => (
        <div class="reveal bg-surface p-7" style={`transition-delay:${i * 70}ms`}>
          <p class="font-display text-lg text-accent">{h.k}</p>
          <p class="mt-2 text-[0.95rem] leading-relaxed text-muted">{h.v}</p>
        </div>
      ))}
    </div>
  </div>
</section>
