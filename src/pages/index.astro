---
import Base from '../layouts/Base.astro';
import Hero from '../components/sections/Hero.astro';
import About from '../components/sections/About.astro';
import Work from '../components/sections/Work.astro';
import Showcase from '../components/sections/Showcase.astro';
import Experience from '../components/sections/Experience.astro';
import Principles from '../components/sections/Principles.astro';
import Skills from '../components/sections/Skills.astro';
import Contact from '../components/sections/Contact.astro';
---
<Base>
  <Hero />
  {/* Straight after the hero: the positioning statement is immediately followed by products a
      visitor can open. Everything below it — the narrative, the case studies — is for someone
      already convinced enough to keep scrolling. */}
  <Showcase />
  <About />
  <Experience />
  <Principles />
  <Work />
  <Skills />
  <Contact />
</Base>
