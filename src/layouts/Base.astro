---
// Fonts are self-hosted rather than fetched from Google. Two reasons: they load from our own
// origin, so there's no second DNS+TLS handshake in front of a render-blocking stylesheet; and
// no visitor IP reaches Google — which the consent banner would otherwise have to account for,
// since analytics is gated but this was not (a German court has ruled on exactly that).
// Fraunces uses the opsz build: it runs from 15px labels to 60px headings, and the optical-size
// axis is what keeps both ends right — the Google URL was requesting it too.
import '@fontsource-variable/inter';
import '@fontsource-variable/fraunces/opsz.css';

import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ChatWidget from '../components/Chat/ChatWidget.tsx';
import CookieBanner from '../components/CookieBanner.tsx';
import { profile } from '../data/site';

interface Props { title?: string; description?: string; }
const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${profile.name}` : profile.seoTitle;
const desc = description ?? profile.seoDescription;

// Absolute URLs (required for canonical + social image).
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL('/og.png', Astro.site).href;

// The Person schema below claims "this URL is the page about Souhaib", so exactly one page may
// carry it. Emitting it from the layout put it on /privacy too, leaving two URLs making that
// same claim for a search engine to pick between.
const isHome = Astro.url.pathname === '/';

// JSON-LD Person schema — tells search engines who this is and links identities.
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: profile.name,
  jobTitle: profile.title,
  description: profile.seoDescription,
  url: Astro.site?.href,
  image: ogImage,
  email: `mailto:${profile.email}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'München',
    addressCountry: 'DE',
  },
  worksFor: { '@type': 'Organization', name: 'parcelLab' },
  alumniOf: { '@type': 'CollegeOrUniversity', name: 'ESPRIT — School of Engineering' },
  knowsAbout: [
    'Artificial Intelligence', 'LLM agents', 'React', 'TypeScript', 'Python',
    'Frontend architecture', 'Design systems', 'Accessibility',
  ],
  sameAs: [profile.links.linkedin, profile.links.github],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    {/* iOS ignores SVG icons: without this, a home-screen bookmark is a page screenshot. Square
        and opaque on purpose — iOS applies its own mask, and would composite alpha onto black. */}
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    <meta name="author" content={profile.name} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    {/* Open Graph — LinkedIn / Facebook / Slack previews */}
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={profile.name} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${profile.name} — ${profile.title}`} />

    {/* Twitter / X card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={`${profile.name} — ${profile.title}`} />

    <meta name="theme-color" content="#faf8f4" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#0d0f12" media="(prefers-color-scheme: dark)" />

    {/* Structured data — Person schema. Home only: see `isHome`. */}
    {isHome && <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />}

    {/* Set theme before paint to avoid a flash */}
    <script is:inline>
      (() => {
        const saved = localStorage.getItem('theme');
        const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        if (saved === 'dark' || (!saved && prefersDark)) document.documentElement.classList.add('dark');
      })();
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <div id="scroll-progress" class="fixed left-0 top-0 z-50 h-[3px] bg-accent" style="width:0"></div>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-full focus:bg-surface focus:px-4 focus:py-2">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />

    {/* AI chat assistant — a React island; hydrates when the browser is idle */}
    <ChatWidget client:idle />

    {/* Cookie consent — client-only React island; only shown when analytics is live */}
    <CookieBanner client:only="react" />

    {/* Analytics — env-gated AND consent-gated: boots only after the visitor accepts */}
    <script>
      import { initAnalytics } from '../lib/analytics';
      initAnalytics();
    </script>

    <button id="back-to-top" type="button" aria-label="Back to top"
      class="fixed bottom-6 right-6 z-40 grid h-11 w-11 place-items-center rounded-full border border-line bg-surface text-muted opacity-0 shadow-[var(--shadow-md)] transition-opacity duration-300 hover:border-accent hover:text-accent pointer-events-none">
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M5 12l7-7 7 7"/></svg>
    </button>

    {/* Scroll reveal */}
    <script is:inline>
      (() => {
        const els = document.querySelectorAll('.reveal');
        if (!('IntersectionObserver' in window) || window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          els.forEach((el) => el.classList.add('in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => entries.forEach((e) => { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } }),
          { threshold: 0.12, rootMargin: '0px 0px -8% 0px' }
        );
        els.forEach((el) => io.observe(el));
      })();
    </script>

    {/* Scroll progress + back-to-top */}
    <script is:inline>
      (() => {
        const prog = document.getElementById('scroll-progress');
        const toTop = document.getElementById('back-to-top');
        const h = document.documentElement;
        const update = () => {
          const max = h.scrollHeight - h.clientHeight;
          if (prog) prog.style.width = (max > 0 ? (h.scrollTop / max) * 100 : 0) + '%';
          if (toTop) {
            const show = h.scrollTop > 600;
            toTop.classList.toggle('opacity-0', !show);
            toTop.classList.toggle('pointer-events-none', !show);
          }
        };
        update();
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('resize', update);
        toTop?.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }));
      })();
    </script>
  </body>
</html>
